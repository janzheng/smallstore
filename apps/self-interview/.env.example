# Self-Interview App — Environment Variables
#
# Copy this to .env and fill in your API key.
# Only ONE provider key is needed.

# --- AI Provider (pick one) ---

# Generic API key (works with any OpenAI-compatible endpoint)
# INTERVIEW_API_KEY=your_api_key_here

# Groq (free, fast — recommended for development)
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI (paid, higher quality)
# OPENAI_API_KEY=sk-your_openai_api_key_here

# --- Storage ---
# Set SM_SHEET_URL to use Google Sheets (sheetlog) instead of local SQLite.
# SM_SHEET_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
# INTERVIEW_SHEET_NAME=self-interview    # Sheet tab name (default: self-interview)

# --- Optional overrides ---

# INTERVIEW_MODEL=llama-3.3-70b-versatile    # Groq default
# INTERVIEW_MODEL=gpt-4o-mini                # OpenAI default
# INTERVIEW_API_URL=https://api.openai.com/v1  # Custom OpenAI-compatible endpoint
# INTERVIEW_PORT=9998
# INTERVIEW_DATA_DIR=./data/self-interview
# INTERVIEW_VERBOSE=true

# --- Custom API (Ollama, LM Studio, Together, etc.) ---
# Set INTERVIEW_API_URL to your endpoint and provide an API key if needed.
# Examples:
#   INTERVIEW_API_URL=http://localhost:11434/v1    # Ollama
#   INTERVIEW_API_URL=http://localhost:1234/v1     # LM Studio
#   INTERVIEW_API_URL=https://api.together.xyz/v1  # Together AI
#
# You can also configure these per-session in the web UI settings panel.
