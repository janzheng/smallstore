# Test data (created by live-adapters.test.ts)
tests/.data/

# Local data (created by serve.ts, examples, apps)
data/
examples/*/data/
apps/*/data/

# Environment files
.env
.env.local

# Local server config (see examples/.smallstore.json.example)
.smallstore.json

# OS files
.DS_Store

# Deno
.deno/

# Stray deno.lock inside deploy/ (created if `deno test` runs from that
# directory — the real lock lives at the repo root).
deploy/deno.lock

# npm build output
dist/
node_modules/
