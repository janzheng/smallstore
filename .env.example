# ============================================================================
# Smallstore Environment Configuration
# ============================================================================
#
# Copy to .env and fill in your values.
# This file covers all apps and adapters in the project.
#
# ============================================================================

# ============================================================================
# AI / LLM Provider Keys
# ============================================================================
# Add the API key(s) for the provider(s) you want to use.
# At least one is needed for apps that make LLM calls (e.g. self-interview).

GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
NVIDIA_INFERENCE_KEY=your-nvidia-inference-api-key

# ============================================================================
# Global AI Defaults (optional)
# ============================================================================
# These override auto-detection. Without them, the first available key is used
# in priority order: groq > nvidia > openai.
#
# Supported providers: groq, openai, nvidia, anthropic
# Or set INTERVIEW_API_URL for any OpenAI-compatible endpoint.

# DEFAULT_PROVIDER=groq
# DEFAULT_MODEL=moonshotai/kimi-k2-instruct

# ============================================================================
# Available Provider / Model Combos
# ============================================================================
#
# Groq (fast, free tier):
#   DEFAULT_PROVIDER=groq
#   DEFAULT_MODEL=moonshotai/kimi-k2-instruct     # 256k context, fast
#   DEFAULT_MODEL=llama-3.3-70b-versatile          # general purpose
#
# OpenAI:
#   DEFAULT_PROVIDER=openai
#   DEFAULT_MODEL=gpt-4o-mini                      # fast, cheap
#   DEFAULT_MODEL=gpt-4o                           # multimodal flagship
#
# NVIDIA Inference (routes to multiple backends):
#   DEFAULT_PROVIDER=nvidia
#   DEFAULT_MODEL=aws/anthropic/bedrock-claude-opus-4-6
#   DEFAULT_MODEL=openai/openai/gpt-5.4
#   DEFAULT_MODEL=meta/llama-3.3-70b-instruct
#
# Anthropic (native API — note: uses Messages API, not OpenAI-compatible):
#   DEFAULT_PROVIDER=anthropic
#   DEFAULT_MODEL=claude-sonnet-4-20250514
#
# Custom / Local (Ollama, LM Studio, Together, etc.):
#   INTERVIEW_API_KEY=your-key-if-needed
#   INTERVIEW_API_URL=http://localhost:11434/v1     # Ollama
#   INTERVIEW_API_URL=http://localhost:1234/v1      # LM Studio
#   INTERVIEW_API_URL=https://api.together.xyz/v1   # Together AI

# ============================================================================
# Self-Interview App Settings
# ============================================================================

# INTERVIEW_PORT=9998
# INTERVIEW_SHEET_NAME=self-interview
# INTERVIEW_DATA_DIR=./data/self-interview
# INTERVIEW_VERBOSE=true

# Override model/endpoint per-app (takes precedence over DEFAULT_*):
# INTERVIEW_MODEL=llama-3.3-70b-versatile
# INTERVIEW_API_URL=https://api.groq.com/openai/v1
# INTERVIEW_API_KEY=your-key-here

# ============================================================================
# Embedding Providers (for search module)
# ============================================================================
# EMBED_PROVIDER=huggingface                        # or "openai"
# EMBED_MODEL=BAAI/bge-small-en-v1.5                # HuggingFace default (384 dims, free)
# EMBED_MODEL=text-embedding-3-small                # OpenAI default
# HUGGINGFACE_API_KEY=hf_your_token_here
# HF_TOKEN=hf_your_token_here                       # alternative
# HF_INFERENCE_URL=https://router.huggingface.co/hf-inference
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================================
# Smallstore API Server
# ============================================================================
# COVERFLOW_API_KEY=your-api-key
# COVERFLOW_API_KEY_ENABLED=false

# ============================================================================
# Storage Adapters (SM_ prefix for test isolation)
# ============================================================================

# --- Upstash Redis ---
# https://console.upstash.com/
SM_UPSTASH_URL=https://your-instance.upstash.io
SM_UPSTASH_TOKEN=your-upstash-token

# --- Airtable ---
# https://airtable.com/create/tokens
SM_AIRTABLE_API_KEY=patXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SM_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
SM_AIRTABLE_TABLE_NAME=SmallstoreTest

# --- Notion ---
# https://www.notion.so/my-integrations
# IMPORTANT: Use the CHILD DATABASE ID, not the page ID from the URL!
SM_NOTION_SECRET=secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SM_NOTION_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SM_NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Sheetlog (Google Sheets) ---
# https://github.com/yawnxyz/sheetlog
SM_SHEET_URL=https://script.google.com/macros/s/your-script-id/exec
SM_SHEET_NAME=SmallstoreTest

# --- Cloudflare Workers (KV / D1 / DO via HTTP) ---
SM_WORKERS_URL=https://your-workers.your-subdomain.workers.dev

# --- Cloudflare R2 (Object Storage) ---
SM_R2_ACCOUNT_ID=your-cloudflare-account-id
SM_R2_ACCESS_KEY_ID=your-r2-access-key-id
SM_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
SM_R2_BUCKET_NAME=smallstore-test

# --- Fuzzyfile (F2) — R2 via Cloudflare Worker ---
# https://f2.phage.directory
F2_DEFAULT_URL=https://f2.phage.directory
F2_AUTH_KEY=your-f2-auth-key

# ============================================================================
# Debug
# ============================================================================
# SMALLSTORE_DEBUG=true
