# ============================================================================
# Smallstore Test Environment Variables
# ============================================================================
#
# Copy to project root .env and fill in your values.
# All variables prefixed with SM_ are specific to Smallstore testing.
#
# Run tests: deno test --allow-all tests/live-adapters.test.ts
# ============================================================================

# ============================================================================
# Upstash Redis
# Get credentials at: https://console.upstash.com/
# ============================================================================
SM_UPSTASH_URL=https://your-instance.upstash.io
SM_UPSTASH_TOKEN=your-upstash-token

# ============================================================================
# Airtable
# Get API key at: https://airtable.com/create/tokens
# Base ID is in the URL: airtable.com/appXXXXXXXXXXXX/...
#
# Required table structure:
#   - Name (Single line text) [required]
#   - Email (Email)
#   - Notes (Long text)
# ============================================================================
SM_AIRTABLE_API_KEY=patXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SM_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
SM_AIRTABLE_TABLE_NAME=SmallstoreTest

# ============================================================================
# Notion
# Create integration at: https://www.notion.so/my-integrations
# IMPORTANT: Use the CHILD DATABASE ID, not the page ID from the URL!
# Full-page databases have a separate child block with a different ID.
# Find it via: Notion API → GET /v1/blocks/{page_id}/children → child_database type
#
# Required database properties:
#   - Name (Title) [required]
#   - Email (Email)
#   - Notes (Text)
#
# Don't forget to share the database with your integration!
# ============================================================================
SM_NOTION_SECRET=secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SM_NOTION_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SM_NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Sheetlog (Google Sheets)
# See: https://github.com/yawnxyz/sheetlog
# ============================================================================
SM_SHEET_URL=https://script.google.com/macros/s/your-script-id/exec
SM_SHEET_NAME=SmallstoreTest

# ============================================================================
# Cloudflare Workers (KV / D1 / DO via HTTP)
# Deploy the smallstore-workers service, then set the URL here.
# All three adapters (KV, D1, DO) use HTTP mode via this single URL.
# Also accepts COVERFLOW_WORKERS_URL for backward compatibility.
# ============================================================================
SM_WORKERS_URL=https://your-workers.your-subdomain.workers.dev

# ============================================================================
# Cloudflare R2 (Object Storage)
# Get credentials: Cloudflare Dashboard > R2 > Manage R2 API Tokens
# ============================================================================
SM_R2_ACCOUNT_ID=your-cloudflare-account-id
SM_R2_ACCESS_KEY_ID=your-r2-access-key-id
SM_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
SM_R2_BUCKET_NAME=smallstore-test

# ============================================================================
# Fuzzyfile (F2) — R2 via Cloudflare Worker
# F2 wraps R2 with presigned URLs, deterministic keys, and CRUD.
# See: https://f2.phage.directory
# ============================================================================
F2_DEFAULT_URL=https://f2.phage.directory
# Auth key for destructive operations (delete, rename). Must match DELETE_AUTH_KEY on the F2 worker.
F2_AUTH_KEY=your-f2-auth-key
