  "dependencies": {
    "@yawnxyz/smallstore": "file:../dist",
    "hono": "^4.10.3",
    "postal-mime": "^2.4.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "wrangler": "^4.84.1"
  }
}
