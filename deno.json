{
  "name": "@yawnxyz/smallstore",
  "version": "0.1.4",
  "exports": {
    ".": "./mod.ts",
    "./adapters/memory": "./src/adapters/memory.ts",
    "./adapters/upstash": "./src/adapters/upstash.ts",
    "./adapters/airtable": "./src/adapters/airtable.ts",
    "./adapters/notion": "./src/adapters/notion.ts",
    "./adapters/sheetlog": "./src/adapters/sheetlog.ts",
    "./adapters/sqlite": "./src/adapters/sqlite.ts",
    "./adapters/structured-sqlite": "./src/adapters/structured-sqlite.ts",
    "./adapters/local-json": "./src/adapters/local-json.ts",
    "./adapters/local-file": "./src/adapters/local-file.ts",
    "./adapters/deno-fs": "./src/adapters/deno-fs.ts",
    "./adapters/overlay": "./src/adapters/overlay.ts",
    "./adapters/r2-direct": "./src/adapters/r2-direct.ts",
    "./adapters/f2-r2": "./src/adapters/f2-r2.ts",
    "./adapters/unstorage": "./src/adapters/unstorage.ts",
    "./adapters/cloudflare-kv": "./src/adapters/cloudflare-kv.ts",
    "./adapters/cloudflare-d1": "./src/adapters/cloudflare-d1.ts",
    "./adapters/cloudflare-do": "./src/adapters/cloudflare-do.ts",
    "./adapters/cloudflare-r2": "./src/adapters/cloudflare-r2.ts",
    "./search": "./src/search/mod.ts",
    "./graph": "./src/graph/mod.ts",
    "./episodic": "./src/episodic/mod.ts",
    "./disclosure": "./src/disclosure/mod.ts",
    "./blob-middleware": "./src/blob-middleware/mod.ts",
    "./views": "./src/views/mod.ts",
    "./materializers": "./src/materializers/mod.ts",
    "./http": "./src/http/mod.ts",
    "./sync": "./src/sync.ts",
    "./vfs": "./apps/cli/vfs.ts",
    "./presets": "./presets.ts",
    "./config": "./config.ts"
  },
  "tasks": {
    "build:npm": "deno run -A scripts/build-npm.ts",
    "build:check": "deno publish --dry-run",
    "serve": "deno run --allow-all serve.ts",
    "serve:watch": "deno run --allow-all --watch serve.ts",
    "test": "deno test --no-check --allow-all tests/",
    "test:api": "deno test --no-check --allow-all tests/api.test.ts",
    "test:core": "deno test --no-check --allow-all tests/sqlite.test.ts tests/batch.test.ts tests/glob.test.ts tests/patch.test.ts tests/presets.test.ts tests/matrix.test.ts tests/structured-sqlite.test.ts tests/sqlite-query.test.ts tests/local-file.test.ts tests/list-collections.test.ts tests/preset-structured.test.ts tests/search.test.ts tests/view.test.ts",
    "test:unit": "deno test --no-check --allow-all tests/graph.test.ts tests/episodic.test.ts tests/disclosure.test.ts",
    "test:live": "deno test --no-check --allow-all tests/live-adapters.test.ts",
    "check": "deno check mod.ts",
    "cli": "deno run --allow-all apps/cli/mod.ts",
    "sh": "deno run --allow-all apps/cli/mod.ts sh",
    "vfs": "deno run --allow-all apps/cli/mod.ts vfs",
    "api": "deno run --allow-all apps/api/mod.ts",
    "clipper": "deno run --allow-all examples/data-clipper/mod.ts",
    "clipper:clean": "deno run --allow-all examples/data-clipper/mod.ts --clean",
    "crm": "deno run --allow-all examples/mini-crm/mod.ts",
    "crm:clean": "deno run --allow-all examples/mini-crm/mod.ts --clean",
    "clipper:sim": "deno run --allow-all examples/data-clipper/simulate.ts",
    "crm:sim": "deno run --allow-all examples/mini-crm/simulate.ts",
    "clipper:sheets": "deno run --allow-all examples/data-clipper/simulate-sheets.ts",
    "auth": "deno run --allow-all examples/tiny-auth/mod.ts",
    "auth:clean": "deno run --allow-all examples/tiny-auth/mod.ts --clean",
    "auth:sim": "deno run --allow-all examples/tiny-auth/simulate.ts",
    "auth:airtable": "deno run --allow-all examples/tiny-auth/airtable.ts",
    "gallery": "deno run --allow-all examples/media-gallery/simulate.ts",
    "gallery:clean": "deno run --allow-all examples/media-gallery/simulate.ts --clean",
    "gallery:live": "deno run --allow-all examples/media-gallery/simulate.ts --live",
    "paste": "deno run --allow-all examples/md-paste/mod.ts",
    "paste:serve": "deno run --allow-all examples/md-paste/serve.ts",
    "test:blobs": "deno test --no-check --allow-all tests/blob-middleware.test.ts",
    "live:airtable": "deno run --allow-all tests/live/airtable/test.ts",
    "live:r2": "deno run --allow-all tests/live/r2/test.ts",
    "live:notion": "deno run --allow-all tests/live/notion/test.ts",
    "live:sheets": "deno run --allow-all tests/live/sheetlog/test.ts",
    "live:blobs": "deno run --allow-all tests/live/blobs/test.ts",
    "live:airtable-blobs": "deno run --allow-all tests/live/airtable-blobs/test.ts",
    "live:notion-blobs": "deno run --allow-all tests/live/notion-blobs/test.ts",
    "live:cleanup": "deno run --allow-all tests/live/cleanup.ts",
    "live:notion-graph-crm": "deno run --allow-all tests/live/notion-graph-crm/test.ts",
    "live:notion-episodic": "deno run --allow-all tests/live/notion-episodic/test.ts",
    "live:notion-wiki": "deno run --allow-all tests/live/notion-wiki/test.ts",
    "live:sheetlog-disclosure": "deno run --allow-all tests/live/sheetlog-disclosure/test.ts",
    "live:sheetlog-views": "deno run --allow-all tests/live/sheetlog-views/test.ts",
    "live:multi-adapter": "deno run --allow-all tests/live/multi-adapter-network/test.ts",
    "test:obsidian": "deno test --no-check --allow-all tests/obsidian-codec.test.ts tests/obsidian-adapter.test.ts",
    "test:obsidian:sync": "deno test --no-check --allow-all tests/obsidian-sync.test.ts",
    "live:obsidian-notion": "deno run --allow-all tests/live/obsidian-notion/test.ts",
    "test:sync": "deno test --no-check --allow-all tests/sync-adapters.test.ts",
    "interview": "deno run --allow-all apps/self-interview/cli.ts",
    "interview:serve": "deno run --allow-all apps/self-interview/mod.ts",
    "interview:serve:watch": "deno run --allow-all --watch apps/self-interview/mod.ts",
    "interview:deploy:dev": "cd apps/self-interview && deno deploy --app 'self-interview'",
    "interview:deploy:prod": "cd apps/self-interview && deno deploy --app 'self-interview' --prod"
  },
  "imports": {
    "hono": "npm:hono@^4.10.3",
    "@notionhq/client": "npm:@notionhq/client@^2.3.0",
    "@notionhq/client/": "npm:@notionhq/client@^2.3.0/",
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.0.0",
    "@aws-sdk/s3-request-presigner": "npm:@aws-sdk/s3-request-presigner@^3.0.0",
    "unstorage": "npm:unstorage@^1.17.0",
    "unstorage/": "npm:unstorage@^1.17.0/",
    "@upstash/redis": "npm:@upstash/redis@^1.34.0",
    "@db/sqlite": "jsr:@db/sqlite@0.12",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "jsr:@std/path": "jsr:@std/path@^1.0.0",
    "@std/fs": "jsr:@std/fs@^1.0.0",
    "@std/fs/walk": "jsr:@std/fs@^1.0.0/walk",
    "@std/fs/ensure-dir": "jsr:@std/fs@^1.0.0/ensure-dir",
    "@std/fs/copy": "jsr:@std/fs@^1.0.0/copy",
    "@std/cli": "jsr:@std/cli@^1.0.0",
    "@std/cli/parse-args": "jsr:@std/cli@^1.0.0/parse-args",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.0",
    "@std/dotenv/load": "jsr:@std/dotenv@^0.225.0/load"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "lib": [
      "deno.ns",
      "deno.unstable",
      "dom",
      "dom.iterable"
    ]
  },
  "publish": {
    "include": [
      "mod.ts",
      "presets.ts",
      "config.ts",
      "src/**/*.ts",
      "apps/cli/**/*.ts",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "src/**/examples/",
      "src/**/tests/",
      "src/**/*.test.ts",
      "src/**/*.manual.ts",
      "**/*.examples.ts"
    ]
  },
  "exclude": [
    "node_modules/",
    "dist/"
  ]
}
